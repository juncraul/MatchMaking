@page "/"

<PageTitle>MatchMaking App</PageTitle>

<div class="text-center mb-5">
    <h1 class="display-4">Welcome to MatchMaking</h1>
    <p class="lead">A fun voting app where you can choose between users and see who ranks highest!</p>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h5 class="card-title">👥 Manage Users</h5>
                <p class="card-text">Add users to the system with their information and photos.</p>
                <a href="/users" class="btn btn-primary">Manage Users</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h5 class="card-title">❤️ Matchmaking</h5>
                <p class="card-text">Vote for your favorite users in head-to-head matchups.</p>
                <a href="/matchmaking" class="btn btn-success">Start Voting</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center">
            <div class="card-body">
                <h5 class="card-title">🏆 Rankings</h5>
                <p class="card-text">View the leaderboard and see who has the most votes.</p>
                <a href="/rankings" class="btn btn-warning">View Rankings</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card bg-light">
            <div class="card-body">
                <h5 class="card-title">How It Works</h5>
                <ol>
                    <li><strong>Add Users:</strong> Start by adding users to the system with their name, sex, age, and photo.</li>
                    <li><strong>Vote:</strong> In the matchmaking section, you'll be shown pairs of users - choose your favorite!</li>
                    <li><strong>Rank:</strong> Each vote gives a point to the selected user. Check rankings to see who's winning.</li>
                </ol>
            </div>
        </div>
    </div>
</div>
