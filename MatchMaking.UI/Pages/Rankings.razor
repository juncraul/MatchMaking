@page "/rankings"
@using MatchMaking.UI.Models
@using MatchMaking.UI.Services
@inject UserService UserService

<PageTitle>Rankings</PageTitle>

<h3>User Rankings</h3>

@if (users == null)
{
    <p><em>Loading rankings...</em></p>
}
else if (!users.Any())
{
    <div class="alert alert-info">
        <h4>No rankings available!</h4>
        <p>No users have been voted on yet. Start matchmaking to see rankings.</p>
        <a href="/matchmaking" class="btn btn-primary">Start Matchmaking</a>
    </div>
}
else
{
    <div class="row mb-3">
        <div class="col-12">
            <button class="btn btn-primary" @onclick="LoadRankings">
                <span class="oi oi-refresh"></span> Refresh Rankings
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Rank</th>
                            <th>Picture</th>
                            <th>Name</th>
                            <th>Sex</th>
                            <th>Age</th>
                            <th>Score</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rank = 1;
                        }
                        @foreach (var user in users)
                        {
                            <tr class="@(rank <= 3 ? "table-warning" : "")">
                                <td>
                                    @if (rank == 1)
                                    {
                                        <span class="badge bg-warning text-dark">🥇 @rank</span>
                                    }
                                    else if (rank == 2)
                                    {
                                        <span class="badge bg-secondary">🥈 @rank</span>
                                    }
                                    else if (rank == 3)
                                    {
                                        <span class="badge bg-danger">🥉 @rank</span>
                                    }
                                    else
                                    {
                                        <span>@rank</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.PicturePath))
                                    {
                                        <img src="@user.PicturePath" alt="@user.Name" 
                                             style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white d-inline-flex align-items-center justify-content-center" 
                                             style="width: 50px; height: 50px; border-radius: 50%; font-size: 1.5rem;">
                                            👤
                                        </div>
                                    }
                                </td>
                                <td><strong>@user.Name</strong></td>
                                <td>@user.Sex</td>
                                <td>@user.Age</td>
                                <td>
                                    <span class="badge @(user.Score >= 10 ? "bg-success" : user.Score >= 5 ? "bg-info" : "bg-secondary")">
                                        @user.Score votes
                                    </span>
                                </td>
                                <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Statistics</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Total Users:</strong> @users.Count
                        </div>
                        <div class="col-md-3">
                            <strong>Total Votes:</strong> @users.Sum(u => u.Score)
                        </div>
                        <div class="col-md-3">
                            <strong>Average Score:</strong> @(users.Any() ? Math.Round(users.Average(u => u.Score), 2) : 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Highest Score:</strong> @(users.Any() ? users.Max(u => u.Score) : 0)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<User>? users;

    protected override async Task OnInitializedAsync()
    {
        await LoadRankings();
    }

    private async Task LoadRankings()
    {
        users = await UserService.GetRankingsAsync();
    }
}
